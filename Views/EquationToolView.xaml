<UserControl x:Class="InventoryWpfApp.Views.EquationToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="Решение квадратного уравнения" FontSize="22" FontWeight="Bold" 
                       Foreground="#FF2C3E50" Margin="0,0,0,10"/>
            <TextBlock Text="ax² + bx + c = 0" FontSize="16" Margin="0,0,0,20"/>

            <!-- Ввод коэффициентов -->
            <TextBlock Text="Введите коэффициенты:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Text="a =" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="TbA" Grid.Row="0" Grid.Column="1" Width="120" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="b =" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="TbB" Grid.Row="1" Grid.Column="1" Width="120" HorizontalAlignment="Left" FontSize="14"/>

                <TextBlock Text="c =" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="TbC" Grid.Row="2" Grid.Column="1" Width="120" HorizontalAlignment="Left" FontSize="14"/>
            </Grid>

            <!-- Выбор метода -->
            <TextBlock Text="Метод решения:" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
            <StackPanel Margin="0,0,0,15">
                <RadioButton x:Name="RbDiscriminant" Content="Через дискриминант" FontSize="14" 
                             IsChecked="True" Margin="0,3" GroupName="Method"/>
                <RadioButton x:Name="RbVieta" Content="По теореме Виета" FontSize="14" 
                             Margin="0,3" GroupName="Method"/>
            </StackPanel>

            <!-- Кнопка -->
            <Button Content="Решить" Click="SolveButton_Click" Width="150" Height="35" FontSize="14"
                    Background="#FF2C3E50" Foreground="White" Margin="0,0,0,20"/>

            <!-- Результат -->
            <Border x:Name="ResultPanel" Visibility="Collapsed" Background="#FFF0F8F0" 
                    Padding="20" CornerRadius="5" BorderBrush="#FF27AE60" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Результат:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TbResult" FontSize="14" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Сообщение об ошибке -->
            <Border x:Name="ErrorPanel" Visibility="Collapsed" Background="#FFFDF2F2" 
                    Padding="20" CornerRadius="5" BorderBrush="#FFE74C3C" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Ошибка:" FontSize="16" FontWeight="Bold" Foreground="#FFE74C3C" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TbError" FontSize="14" TextWrapping="Wrap" Foreground="#FFC0392B"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>